# ============================================================
# Jobs Buddy — Local machine config (no deployment needed)
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# ============================================================

# --- Required ---
OPENAI_API_KEY=sk-your-key-here

# --- Local URLs (keep these defaults on your own PC) ---
HOST=127.0.0.1
WORKER_URL=http://127.0.0.1:3001
DASHBOARD_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
WORKER_PORT=3001

# --- Database (stored locally on your machine) ---
DATABASE_URL=file:./data/jobs-buddy.db

# --- LinkedIn (optional — setup script saves session to ./sessions/) ---
LINKEDIN_SESSION_COOKIE=

# --- Indeed (optional) ---
INDEED_EMAIL=
INDEED_PASSWORD=

# --- Notifications (all optional — desktop alerts work without config) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
NOTIFICATION_EMAIL_TO=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# --- Worker behaviour ---
CRON_SCHEDULE=0 9 * * 1-5
MIN_MATCH_SCORE=80
HEADLESS=false
DRY_RUN=false
